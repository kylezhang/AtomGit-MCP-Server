{
  "name": "@atomgit.com/atomgit-mcp-server",
  "version": "2.4.2",
  "description": "AtomGit MCP Server - Model Context Protocol server for AtomGit code hosting platform",
  "main": "dist/index.js",
  "bin": {
    "atomgit-mcp-server": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepack": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "api:sync": "tsx scripts/update_apis.ts",
    "api:map": "tsx scripts/generate_map.ts",
    "api:check": "tsx scripts/analyze_coverage.ts",
    "api:audit": "tsx scripts/audit_api_contracts.ts",
    "api:scaffold": "tsx scripts/scaffold_tool.ts"
  },
  "keywords": [
    "mcp",
    "atomgit",
    "git",
    "model-context-protocol"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylezhang/AtomGit-MCP-Server.git"
  },
  "homepage": "https://atomgit.com/zkxw2008/AtomGit-MCP-Server",
  "bugs": {
    "url": "https://atomgit.com/zkxw2008/AtomGit-MCP-Server/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.17.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "cheerio": "^1.2.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
