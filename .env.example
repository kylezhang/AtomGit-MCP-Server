# AtomGit MCP Server Configuration
# API base URL is fixed to: https://api.atomgit.com
# Get your personal access token from: https://atomgit.com/setting/token-classic
ATOMGIT_TOKEN=your_personal_access_token_here

# Optional: enable dangerous tools such as delete/remove/archive/transfer actions.
# Default is false. Set to true and restart the server only when you explicitly need them.
ATOMGIT_ENABLE_DANGEROUS_TOOLS=false
